#include <ECE3.h>

// Base code.
// 
// *  NOTE: this code will do only three things:
// *    --rotate one wheel, and 
// *    --blink the right front mainboard LED.
// *    
// *  You will need to add more code to
// *  make the car do anything useful. 
// 

uint16_t sensorValues[8]; // right -> left, 0 -> 7

const int left_nslp_pin=31; // nslp ==> awake & ready for PWM
const int left_dir_pin=29;
const int left_pwm_pin=40;

const int right_nslp_pin=11; // nslp ==> awake & ready for PWM
const int right_dir_pin=30;
const int right_pwm_pin=39;

const int LED_RF = 41;

const float speed = 50; 
float rightspeed;
float leftspeed;

const float kp = 0.01; //we can adjust to fix jittering!!!!
float preverror = 0;
const float kd = 0.07;

int blackcounter = 0;

int counter = 0;
bool onmiddle = false;

int leftblackcounter = 0;


void goforward(){
  analogWrite(left_pwm_pin,speed);
  analogWrite(right_pwm_pin,speed);
}

void goright(){
  analogWrite(right_pwm_pin, 0);
  analogWrite(left_pwm_pin, speed);
}

void turnaround(){
  //what do i write here
      // Spin in place: left motor forward, right motor backward
    digitalWrite(left_dir_pin, LOW);   // Left motor forward
    digitalWrite(right_dir_pin, HIGH);   // Right motor backward (or vice versa)

    analogWrite(left_pwm_pin, 60);
    analogWrite(right_pwm_pin, 60);

    delay(380);  // Hold until ~180° rotation is complete

    // Stop motors after turn
    analogWrite(left_pwm_pin, 0);
    analogWrite(right_pwm_pin, 0);

    // Restore forward direction for both motors
    digitalWrite(left_dir_pin, LOW);
    digitalWrite(right_dir_pin, LOW);
}

void hardcodeturn(){
  //what do i write here
      // Spin in place: left motor forward, right motor backward
    digitalWrite(left_dir_pin, HIGH);   // Left motor forward
    digitalWrite(right_dir_pin, LOW);   // Right motor backward (or vice versa)

    analogWrite(left_pwm_pin, 30);
    analogWrite(right_pwm_pin,80);

    delay(1800);  // Hold until ~180° rotation is complete

    // Stop motors after turn
    analogWrite(left_pwm_pin, 0);
    analogWrite(right_pwm_pin, 0);

    // Restore forward direction for both motors
    digitalWrite(left_dir_pin, LOW);
    digitalWrite(right_dir_pin, LOW);
}


///////////////////////////////////
void setup() {
// put your setup code here, to run once:
  pinMode(left_nslp_pin,OUTPUT);
  pinMode(left_dir_pin,OUTPUT);
  pinMode(left_pwm_pin,OUTPUT);

  pinMode(right_nslp_pin,OUTPUT);
  pinMode(right_dir_pin,OUTPUT);
  pinMode(right_pwm_pin,OUTPUT);

  digitalWrite(left_dir_pin,LOW);
  digitalWrite(left_nslp_pin,HIGH);

  digitalWrite(right_dir_pin,LOW);
  digitalWrite(right_nslp_pin,HIGH);

  pinMode(LED_RF, OUTPUT);
  
  ECE3_Init();
  
  rightspeed = speed;
  leftspeed = speed;

// set the data rate in bits/second for serial data transmission
  Serial.begin(9600); 
  delay(2000); //Wait 2 seconds before starting 
  
}

void loop() {
  // put your main code here, to run repeatedly: 



  ECE3_read_IR(sensorValues);
  float errorval = 0;
  errorval+=sensorValues[0]*-15;
  errorval+=sensorValues[1]*-14;
  errorval+=sensorValues[2]*-12;
  errorval+=sensorValues[3]*-8;
  errorval+=sensorValues[4]*8;
  errorval+=sensorValues[5]*12;
  errorval+=sensorValues[6]*14;
  errorval+=sensorValues[7]*15;
  errorval = errorval/4.0;

  float lefterrorval = 0;
  lefterrorval+=sensorValues[6];
  lefterrorval+=sensorValues[7];

  errorval-=2200;
  float derivative = (errorval - preverror);
  float kd_term = derivative * kd;

  if (errorval == preverror && errorval <= -2100 && errorval >= -2300){
    if (blackcounter == 0){
      turnaround();
      //go forward ??
      blackcounter++;
    }
    else if (blackcounter == 1){
      digitalWrite(left_nslp_pin,LOW);
      digitalWrite(right_nslp_pin,LOW);
    }
  }

  if (lefterrorval > 4800 && leftblackcounter == 0){
    goforward();
    delay(400);
    hardcodeturn();
    leftblackcounter++;
    goright();
    delay(50);
    //delay(2700);
  }

  leftspeed = speed - (errorval * kp + kd_term);
  rightspeed = speed + (errorval * kp + kd_term);


  //  Serial.print("errorval ");
  //  Serial.print(errorval);
  //  Serial.print(" lefterrorval ");
  //  Serial.println(lefterrorval);
  //  delay(500);

  analogWrite(left_pwm_pin,leftspeed);
  analogWrite(right_pwm_pin,rightspeed);

  preverror = errorval;

    
  }
